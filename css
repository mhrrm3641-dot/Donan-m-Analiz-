<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Global Cyber Base: Muharrem Gürlüyer liderliğinde küresel siber güvenlik platformu.">
    <title>GLOBAL CYBER BASE | YÖNETİM MERKEZİ</title>
    
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7403038226629562" crossorigin="anonymous"></script>

    <style>
        :root {
            --ana-mavi: #0d6efd;
            --ana-kirmizi: #dc3545;
            --arka-plan: #ffffff;
            --kart-bg: #ffffff;
            --border-renk: #0d6efd;
            --yazi-koyu: #333333;
            --terminal-bg: #1e1e1e;
            --terminal-yazi: #00ff00;
        }

        body { margin: 0; padding: 0; background-color: var(--arka-plan); font-family: 'Segoe UI', sans-serif; color: var(--ana-kirmizi); line-height: 1.6; }
        .grid-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(13, 110, 253, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(13, 110, 253, 0.05) 1px, transparent 1px); background-size: 20px 20px; z-index: -1; }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        
        .vizyon-header { text-align: center; border: 2px solid var(--border-renk); border-radius: 10px; padding: 20px; margin-bottom: 20px; background-color: var(--kart-bg); box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .reklam-alani { margin: 20px 0; text-align: center; background-color: rgba(240, 247, 255, 0.5); border: 1px dashed #ccc; padding: 10px; border-radius: 5px; overflow: hidden; }

        /* Modül Grid */
        .modul-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .modul-kart { border: 2px solid var(--border-renk); border-radius: 10px; padding: 25px 15px; text-align: center; background-color: var(--kart-bg); transition: transform 0.3s; }
        .modul-kart:hover { transform: translateY(-5px); }
        .modul-ikon { font-size: 40px; margin-bottom: 15px; }
        .modul-baslik { color: var(--ana-mavi); font-weight: bold; }
        .modul-buton { background: var(--ana-mavi); color: white; border: none; padding: 10px 25px; border-radius: 5px; cursor: pointer; font-weight: bold; }

        /* Panel ve Terminal */
        .bilgi-paneli { border: 2px solid var(--border-renk); border-radius: 10px; padding: 20px; margin-bottom: 30px; background: var(--kart-bg); }
        #terminal-kapsayici { background: var(--terminal-bg); border-radius: 8px; padding: 15px; margin-bottom: 20px; }
        #analiz-ekrani { color: var(--terminal-yazi); font-family: 'Courier New', monospace; white-space: pre-wrap; margin: 0; }

        /* Admin Paneli Stili */
        #admin-section { margin: 20px 0; padding: 20px; border: 3px solid var(--ana-kirmizi); border-radius: 10px; background: #fff1f1; display: none; }
        .admin-input { width: 100%; padding: 10px; margin-bottom: 10px; border: 1px solid var(--ana-mavi); box-sizing: border-box; }

        footer { text-align: center; padding: 20px; border-top: 2px solid var(--ana-mavi); margin-top: 20px; }
    </style>
</head>
<body>
    <div class="grid-bg"></div>

    <div class="container">
        <div class="vizyon-header">
            <h1>GLOBAL CYBER BASE | GÜÇ VE VİZYON</h1>
        </div>

        <div class="reklam-alani">
            <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-7403038226629562" data-ad-slot="SLOT_1" data-ad-format="auto"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <div class="modul-grid">
            <div class="modul-kart"><div class="modul-ikon">🛡️</div><div class="modul-baslik">Siber Savunma</div><p>Ağ güvenliği aktif.</p><button class="modul-buton">KONTROL ET</button></div>
            <div class="modul-kart"><div class="modul-ikon">🧠</div><div class="modul-baslik">Yapay Zeka</div><p>AI motoru hazır.</p><button class="modul-buton">BAŞLAT</button></div>
            <div class="modul-kart"><div class="modul-ikon">🚀</div><div class="modul-baslik">Hızlı Erişim</div><p>Veri yolu açık.</p><button class="modul-buton">BAĞLAN</button></div>
            <div class="modul-kart"><div class="modul-ikon">🔐</div><div class="modul-baslik">Kripto Birimi</div><p>Deşifre modülü.</p><button class="modul-buton">ÇÖZÜMÜ AÇ</button></div>
        </div>

        <div class="bilgi-paneli">
            <h3>📰 CYBER NEWS</h3>
            <div id="haberler-alani"></div>
        </div>

        <div id="terminal-kapsayici">
            <pre id="analiz-ekrani">Sistem başlatılıyor...</pre>
        </div>

        <div id="admin-section">
            <h2 style="text-align: center;">🛠 YÖNETİM MERKEZİ</h2>
            <input type="text" id="news-title" class="admin-input" placeholder="Haber Başlığı">
            <textarea id="news-content-input" class="admin-input" style="height: 80px;" placeholder="Haber İçeriği"></textarea>
            <button onclick="yeniHaberEkle()" style="background: var(--ana-kirmizi); color: white; padding: 12px; width: 100%; border: none; cursor: pointer; font-weight: bold; margin-bottom: 10px;">YAYINLA</button>
            <button onclick="adminPaneliKapat()" style="background: #333; color: white; padding: 12px; width: 100%; border: none; cursor: pointer;">KİLİTLE</button>
        </div>

        <div style="text-align: center; margin: 20px 0;">
            <button id="admin-login-btn" onclick="adminGirisYap()" style="background: transparent; border: 1px solid #ccc; color: #ccc; font-size: 10px; cursor: pointer;">[ Yönetici Girişi ]</button>
        </div>

        <footer>
            <p>MUHARREM GÜRLÜYER | DONANIM ANALİZ</p>
            <span style="font-size: 12px;">© 2026 Tüm Hakları Saklıdır</span>
        </footer>
    </div>

    <script>
        const siberHaberler = [
            { "baslik": "Global Siber Üs V4.1 Aktif", "tarih": "2026-04-27", "icerik": "Yönetim paneli entegrasyonu tamamlandı." }
        ];

        function haberleriYukle() {
            const haberAlan = document.getElementById('haberler-alani');
            haberAlan.innerHTML = siberHaberler.map(h => `
                <div style="margin-bottom: 15px; border-bottom: 1px dashed #ccc; padding-bottom: 10px;">
                    <strong style="color: var(--ana-kirmizi);">${h.baslik}</strong> <small>[${h.tarih}]</small>
                    <p style="margin: 5px 0 0 0; font-size: 14px; color: #333;">${h.icerik}</p>
                </div>
            `).join('');
        }

        async function verileriEkranaBas() {
            const ekran = document.getElementById('analiz-ekrani');
            const saat = new Date().toLocaleTimeString('tr-TR');
            ekran.innerHTML = `[${saat}] Veri Akışı Stabil.\n> ASELSAN: 154.20 TL\n> BTC: 64,200 USD\n[DURUM]: GÜVENLİ`;
        }

        // --- ADIM 2: ADMİN FONKSİYONLARI ---
        function adminGirisYap() {
            const sifre = prompt("Sistem Şifresi:");
            if (sifre === "siber123") {
                document.getElementById('admin-section').style.display = 'block';
                document.getElementById('admin-login-btn').style.display = 'none';
            } else { alert("Erişim Reddedildi!"); }
        }

        function adminPaneliKapat() {
            document.getElementById('admin-section').style.display = 'none';
            document.getElementById('admin-login-btn').style.display = 'inline-block';
        }

        function yeniHaberEkle() {
            const b = document.getElementById('news-title').value;
            const i = document.getElementById('news-content-input').value;
            if(!b || !i) return alert("Boş bırakma!");
            
            siberHaberler.unshift({ "baslik": b, "tarih": new Date().toLocaleDateString('tr-TR'), "icerik": i });
            haberleriYukle();
            document.getElementById('news-title').value = "";
            document.getElementById('news-content-input').value = "";
            alert("Haber Yayınlandı!");
        }

        window.onload = () => { haberleriYukle(); verileriEkranaBas(); setInterval(verileriEkranaBas, 30000); };
    </script>
</body>
</html>
<section id="cyber-news" style="margin: 20px 0; padding: 15px; border: 1px solid #ddd; background: #f9f9f9;">
  <h3>🌐 Cyber News</h3>
  <div id="news-content">
    </div>
</section>

<div id="terminal-screen" style="background: #000; color: #0f0; padding: 15px; border-radius: 5px; font-family: 'Courier New', monospace; overflow-x: auto; margin-top: 20px;">
  <pre id="analiz-ekrani" style="white-space: pre-wrap; word-wrap: break-word;">
    // Sistem verileri bekleniyor...
  </pre>
</div>
